<svg xmlns="http://www.w3.org/2000/svg" width="800" height="450" viewBox="0 0 800 450">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a0533;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2d0a4e;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="bar" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#e879f9;stop-opacity:0.9" />
      <stop offset="100%" style="stop-color:#e879f9;stop-opacity:0.2" />
    </linearGradient>
  </defs>
  <rect width="800" height="450" fill="url(#bg)"/>
  <!-- Decorative bars -->
  <rect x="40" y="180" width="200" height="6" rx="3" fill="url(#bar)" opacity="0.7"/>
  <rect x="40" y="200" width="140" height="6" rx="3" fill="url(#bar)" opacity="0.5"/>
  <rect x="40" y="220" width="170" height="6" rx="3" fill="url(#bar)" opacity="0.4"/>
  <!-- Right panel mockup -->
  <rect x="460" y="120" width="280" height="160" rx="8" fill="#e879f9" opacity="0.08"/>
  <rect x="460" y="120" width="280" height="160" rx="8" fill="none" stroke="#e879f9" stroke-width="1" opacity="0.2"/>
  <!-- Dots row -->
  <circle cx="480" cy="148" r="5" fill="#e879f9" opacity="0.6"/>
  <circle cx="500" cy="148" r="5" fill="#e879f9" opacity="0.4"/>
  <circle cx="520" cy="148" r="5" fill="#e879f9" opacity="0.2"/>
  <!-- Text placeholders inside panel -->
  <rect x="480" y="168" width="120" height="5" rx="2" fill="white" opacity="0.15"/>
  <rect x="480" y="183" width="80" height="5" rx="2" fill="white" opacity="0.1"/>
  <rect x="480" y="198" width="100" height="5" rx="2" fill="white" opacity="0.08"/>
  <!-- Centered label -->
  <text x="400" y="340" text-anchor="middle" fill="white" opacity="0.9" font-family="system-ui,sans-serif" font-size="22" font-weight="600">Dealer Service Suite</text>
  <text x="400" y="370" text-anchor="middle" fill="white" opacity="0.45" font-family="system-ui,sans-serif" font-size="14">iService</text>
  <!-- Accent bar bottom -->
  <rect x="340" y="390" width="120" height="3" rx="1.5" fill="#e879f9" opacity="0.6"/>
</svg>